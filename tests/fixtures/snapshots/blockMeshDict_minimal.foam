FoamFile
{
	format      ascii;
	class       dictionary;
	object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convertToMeters 1;

geometry
{
}

vertices
(
	// Vertices block0
	name v0 (1.00000000 0.00000000 0.00000000)
	name v1 (2.00000000 0.00000000 0.00000000)
	name v2 (2.00000000 1.00000000 0.00000000)
	name v3 (1.00000000 1.00000000 0.00000000)
	name v4 (1.00000000 0.00000000 1.00000000)
	name v5 (2.00000000 0.00000000 1.00000000)
	name v6 (2.00000000 1.00000000 1.00000000)
	name v7 (1.00000000 1.00000000 1.00000000)
);

edges
(
);

blocks
(
	name block0 hex (v0 v1 v2 v3 v4 v5 v6 v7) (1 1 1) simpleGrading (1 1 1)
);

defaultPatch
{
	name defaultFaces;
	type empty;
}

boundary
(
	outer
	{
		type patch;
		faces
		(
			(v4 v5 v6 v7)	// block0
		);
	}
);

// ************************************************************************* //
